在ubuntu上：
sudo apt install -y chrony
# 编辑 /etc/chrony/chrony.conf，增加：
# allow 192.168.2.0/24
# local stratum 2
# （可选）只在直连口监听：bindaddress 192.168.2.2
sudo systemctl restart chrony
# 防火墙放行 UDP/123（如果开启了 ufw）
sudo ufw allow 123/udp
在下位机：
sudo apt update
sudo apt install -y chrony
sudo timedatectl set-ntp false
sudo systemctl enable --now chrony  # 若报错再试 chronyd
# 把 192.168.2.2 换成你电脑的直连IP（无尖括号）
sudo chronyc -a 'add server 192.168.2.2 iburst'
sudo chronyc -a makestep
chronyc tracking
chronyc sources -v


完全断网：在下位机
sudo timedatectl set-ntp false
sudo date -s "2025-09-03 14:23:45"  # 用你电脑显示的当前本地时间
sudo hwclock -w || true
date

